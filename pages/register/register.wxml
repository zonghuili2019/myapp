<!--pages/register/register.wxml-->
<view class="container">
  <view class="header">
    <text class="title">用户注册</text>
    <text class="subtitle">完善信息，开始使用本地生活服务</text>
  </view>

  <!-- 用户类型选择 -->
  <view class="type-selector">
    <view 
      class="type-item {{userType === 'client' ? 'active' : ''}}" 
      bindtap="switchUserType" 
      data-type="client"
    >
      <view class="type-icon">
        <text class="iconfont">👤</text>
      </view>
      <text class="type-name">我是客户</text>
      <text class="type-desc">发布需求，等待商家接单</text>
    </view>
    <view 
      class="type-item {{userType === 'merchant' ? 'active' : ''}}" 
      bindtap="switchUserType" 
      data-type="merchant"
    >
      <view class="type-icon">
        <text class="iconfont">🏪</text>
      </view>
      <text class="type-name">我是商家</text>
      <text class="type-desc">接收订单，提供服务</text>
    </view>
  </view>

  <!-- 表单 -->
  <view class="form-card">
    <!-- 基本信息 -->
    <view class="form-section">
      <text class="section-title">基本信息</text>
      
      <view class="form-item">
        <text class="form-label">昵称</text>
        <input 
          class="form-input" 
          placeholder="请输入昵称" 
          value="{{form.nickname}}"
          bindinput="onInputChange"
          data-field="nickname"
          maxlength="20"
        />
      </view>

      <view class="form-item">
        <text class="form-label">手机号</text>
        <input 
          class="form-input" 
          type="number"
          placeholder="请输入手机号" 
          value="{{form.phone}}"
          bindinput="onInputChange"
          data-field="phone"
          maxlength="11"
        />
      </view>

      <view class="form-item">
        <text class="form-label">服务地址</text>
        <view class="form-input-wrapper" bindtap="chooseLocation">
          <text class="form-input {{form.location.address ? '' : 'placeholder'}}">
            {{form.location.address || '请选择位置'}}
          </text>
          <text class="input-suffix">📍</text>
        </view>
      </view>
    </view>

    <!-- 商家额外信息 -->
    <view class="form-section" wx:if="{{userType === 'merchant'}}">
      <text class="section-title">商家信息</text>
      
      <view class="form-item">
        <text class="form-label">商家名称</text>
        <input 
          class="form-input" 
          placeholder="请输入商家名称" 
          value="{{form.name}}"
          bindinput="onInputChange"
          data-field="name"
          maxlength="30"
        />
      </view>

      <view class="form-item">
        <text class="form-label">商家简介</text>
        <textarea 
          class="form-textarea" 
          placeholder="请输入商家简介（选填）" 
          value="{{form.description}}"
          bindinput="onInputChange"
          data-field="description"
          maxlength="200"
        />
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <button class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="submitRegister">
    {{submitting ? '注册中...' : '立即注册'}}
  </button>

  <!-- 底部提示 -->
  <view class="footer">
    <text>已有账号？</text>
    <text class="link" bindtap="goBack">返回登录</text>
  </view>
</view>
