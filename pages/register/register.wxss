/* pages/register/register.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 用户类型选择 */
.type-selector {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.type-item {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid #eee;
  transition: all 0.3s;
}

.type-item.active {
  border-color: #07c160;
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.1) 0%, #fff 100%);
}

.type-icon {
  width: 80rpx;
  height: 80rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.type-item.active .type-icon {
  background: #07c160;
}

.iconfont {
  font-size: 40rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin: 12rpx 0;
}

.type-item.active .type-name {
  color: #07c160;
}

.type-desc {
  font-size: 24rpx;
  color: #999;
}

.type-item.active .type-desc {
  color: #666;
}

/* 表单 */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.form-section {
  margin-bottom: 40rpx;
}

.form-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #ccc;
}

.form-input-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
}

.form-input.placeholder {
  color: #ccc;
}

.input-suffix {
  font-size: 28rpx;
  color: #07c160;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-bottom: 40rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #ccc;
  opacity: 0.7;
}

/* 底部 */
.footer {
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

.link {
  color: #07c160;
  margin: 0 4rpx;
}
