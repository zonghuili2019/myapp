<!--pages/login/login.wxml-->
<view class="container">
  <view class="header">
    <text class="title">欢迎回来</text>
    <text class="subtitle">请登录您的账号</text>
  </view>

  <!-- 表单 -->
  <view class="form-card">
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input 
        class="form-input" 
        type="number"
        placeholder="请输入手机号" 
        value="{{phone}}"
        bindinput="onInputChange"
        data-field="phone"
        maxlength="11"
      />
    </view>

    <view class="form-item" wx:if="{{loginType === 'password'}}">
      <text class="form-label">密码</text>
      <view class="password-wrapper">
        <input 
          class="form-input" 
          type="{{showPassword ? 'text' : 'password'}}"
          placeholder="请输入密码" 
          value="{{password}}"
          bindinput="onInputChange"
          data-field="password"
          maxlength="20"
        />
        <text class="eye-icon" bindtap="togglePassword">{{showPassword ? '🔒' : '🔓'}}</text>
      </view>
    </view>

    <view class="form-item" wx:else>
      <text class="form-label">验证码</text>
      <view class="verify-wrapper">
        <input 
          class="form-input" 
          type="number"
          placeholder="请输入验证码" 
          value="{{verifyCode}}"
          bindinput="onInputChange"
          data-field="verifyCode"
          maxlength="6"
        />
        <view class="verify-btn {{countDown > 0 ? 'disabled' : ''}}" bindtap="sendVerifyCode">
          {{countDown > 0 ? countDown + 's后重发' : '获取验证码'}}
        </view>
      </view>
    </view>
  </view>

  <!-- 登录方式切换 -->
  <view class="login-switch">
    <text class="switch-label">登录方式</text>
    <view class="switch-tabs">
      <view 
        class="switch-tab {{loginType === 'password' ? 'active' : ''}}" 
        bindtap="switchLoginType"
      >密码登录</view>
      <view 
        class="switch-tab {{loginType === 'verifyCode' ? 'active' : ''}}" 
        bindtap="switchLoginType"
      >验证码登录</view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <button class="submit-btn {{loggingIn ? 'disabled' : ''}}" bindtap="submitLogin">
    {{loggingIn ? '登录中...' : '登录'}}
  </button>

  <!-- 底部提示 -->
  <view class="footer">
    <view class="footer-row">
      <text>还没有账号？</text>
      <text class="link" bindtap="goToRegister">立即注册</text>
    </view>
    <view class="footer-row">
      <text>忘记密码？</text>
      <text class="link">找回密码</text>
    </view>
  </view>
</view>
