/* pages/login/login.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 表单 */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #ccc;
}

.password-wrapper {
  position: relative;
}

.password-wrapper .form-input {
  padding-right: 80rpx;
}

.eye-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

.verify-wrapper {
  display: flex;
  gap: 16rpx;
}

.verify-wrapper .form-input {
  flex: 1;
}

.verify-btn {
  padding: 0 24rpx;
  height: 96rpx;
  line-height: 96rpx;
  background: #07c160;
  color: #fff;
  font-size: 26rpx;
  border-radius: 16rpx;
}

.verify-btn.disabled {
  background: #ccc;
  color: #999;
}

/* 登录方式切换 */
.login-switch {
  margin-bottom: 24rpx;
}

.switch-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.switch-tabs {
  display: flex;
  gap: 16rpx;
}

.switch-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid #eee;
}

.switch-tab.active {
  border-color: #07c160;
  color: #07c160;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-bottom: 40rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #ccc;
  opacity: 0.7;
}

/* 底部 */
.footer {
  text-align: center;
}

.footer-row {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.link {
  color: #07c160;
  margin: 0 4rpx;
}
