page {
  background: #f5f7fb;
}

.page {
  padding: 32rpx;
  padding-bottom: 80rpx;
}

.hero-card {
  background: linear-gradient(135deg, #07c160 0%, #0bbf78 100%);
  border-radius: 28rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-start;
  margin-bottom: 24rpx;
  color: #fff;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.hero-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}

.hero-tag {
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.summary-card,
.map-card,
.filter-card,
.merchant-card,
.empty-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(31, 45, 61, 0.05);
}

.summary-card,
.map-card,
.filter-card,
.empty-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.summary-label {
  display: block;
  font-size: 24rpx;
  color: #98a2b3;
  margin-bottom: 10rpx;
}

.summary-value {
  display: block;
  font-size: 30rpx;
  color: #101828;
  font-weight: 500;
}

.summary-value.address {
  line-height: 1.6;
}

.summary-grid {
  margin-top: 24rpx;
  display: flex;
  align-items: stretch;
  gap: 20rpx;
}

.mini-stat,
.mini-action {
  flex: 1;
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 24rpx;
}

.mini-stat-value {
  display: block;
  font-size: 34rpx;
  color: #07c160;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.mini-stat-label {
  font-size: 24rpx;
  color: #667085;
}

.mini-action {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #07c160;
  font-size: 28rpx;
  font-weight: 500;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  color: #101828;
  font-weight: 600;
}

.section-subtitle {
  font-size: 22rpx;
  color: #98a2b3;
}

.merchant-map {
  width: 100%;
  height: 360rpx;
  border-radius: 20rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  height: 68rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #667085;
  font-size: 24rpx;
}

.filter-chip.active {
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
  font-weight: 600;
}

.merchant-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.merchant-card {
  padding: 28rpx;
}

.merchant-top {
  display: flex;
  gap: 24rpx;
}

.merchant-logo {
  width: 108rpx;
  height: 108rpx;
  border-radius: 24rpx;
  background: #f2f4f7;
  flex-shrink: 0;
}

.merchant-main {
  flex: 1;
}

.merchant-name-row,
.merchant-meta-row,
.merchant-info-row,
.merchant-address-row,
.action-row,
.tag-list {
  display: flex;
  align-items: center;
}

.merchant-name-row {
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.merchant-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #101828;
}

.merchant-distance {
  font-size: 24rpx;
  color: #07c160;
  font-weight: 600;
}

.merchant-meta-row {
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.merchant-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.merchant-badge.rating {
  background: rgba(255, 184, 0, 0.12);
  color: #d48806;
}

.merchant-badge.category {
  background: rgba(24, 144, 255, 0.12);
  color: #1890ff;
}

.merchant-badge.eta {
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
}

.merchant-desc {
  display: block;
  font-size: 24rpx;
  color: #667085;
  line-height: 1.7;
}

.tag-list {
  gap: 12rpx;
  flex-wrap: wrap;
  margin: 24rpx 0 16rpx;
}

.tag-item {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #475467;
  font-size: 22rpx;
}

.merchant-info-row {
  gap: 10rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}

.info-label {
  color: #98a2b3;
}

.info-value {
  color: #344054;
  font-weight: 500;
}

.info-value.price {
  color: #ff4d4f;
}

.info-divider {
  color: #d0d5dd;
}

.merchant-address-row {
  gap: 10rpx;
  margin-bottom: 12rpx;
  align-items: flex-start;
}

.address-icon {
  font-size: 24rpx;
  line-height: 1.6;
}

.address-text {
  flex: 1;
  font-size: 24rpx;
  color: #667085;
  line-height: 1.6;
}

.action-row {
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
}

.action-btn.secondary {
  background: #f5f7fa;
  color: #344054;
}

.action-btn.primary {
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  color: #fff;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #101828;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #98a2b3;
}
