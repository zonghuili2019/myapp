<!--pages/index/index.wxml-->
<view class="container">
  <!-- 加载动画 -->
  <view class="loading-container" wx:if="{{isLoading}}">
    <view class="logo">
      <view class="logo-icon">
        <text class="iconfont">📍</text>
      </view>
    </view>
    <view class="loading-text">
      <text class="main-text">本地生活服务</text>
      <text class="sub-text">正在加载...</text>
    </view>
    <view class="loading-dots">
      <view class="dot"></view>
      <view class="dot"></view>
      <view class="dot"></view>
    </view>
  </view>

  <!-- 登录区域 -->
  <view class="login-container" wx:else>
    <button
      class="login-btn"
      bindtap="handleLogin"
      loading="{{isLoggingIn}}"
      disabled="{{isLoggingIn}}"
    >
      <view class="login-icon" wx:if="{{!avatarUrl}}">
        <text class="iconfont">👤</text>
      </view>
      <image class="avatar-image" wx:else src="{{avatarUrl}}" mode="aspectFill"></image>
      <text class="login-text">{{isLoggingIn ? '登录中...' : '微信一键登录'}}</text>
    </button>

    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">其他登录方式</text>
      <view class="divider-line"></view>
    </view>

    <view class="other-login">
      <view class="login-item" bindtap="goToRegister">
        <text class="iconfont">📝</text>
        <text>注册账号</text>
      </view>
      <view class="login-item" bindtap="goToLogin">
        <text class="iconfont">🔑</text>
        <text>账号登录</text>
      </view>
    </view>

    <view class="footer-tip">
      <text>登录即表示同意</text>
      <text class="link">《用户协议》</text>
      <text>和</text>
      <text class="link">《隐私政策》</text>
    </view>
  </view>
</view>
