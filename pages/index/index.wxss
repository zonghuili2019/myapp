/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #07c160 0%, #06ae56 100%);
  padding: 60rpx 40rpx;
}

/* 加载动画 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  margin-bottom: 40rpx;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  background: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
}

.iconfont {
  font-size: 80rpx;
}

.loading-text {
  text-align: center;
  margin-bottom: 60rpx;
}

.main-text {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.sub-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.loading-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #fff;
  border-radius: 50%;
  animation: dotPulse 1.4s infinite ease-in-out;
}

.dot:nth-child(1) {
  animation-delay: -0.32s;
}

.dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes dotPulse {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 登录区域 */
.login-container {
  width: 100%;
  padding-top: 100rpx;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  width: 100%;
  height: 112rpx;
  background: #fff;
  border-radius: 56rpx;
  border: none;
  margin-bottom: 60rpx;
}

.login-btn::after {
  border: none;
}

.login-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.iconfont {
  font-size: 40rpx;
}

.login-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.avatar-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #eee;
}

.divider-text {
  padding: 0 32rpx;
  font-size: 26rpx;
  color: #999;
}

.other-login {
  display: flex;
  gap: 40rpx;
}

.login-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 48rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx solid #eee;
}

.login-item text:first-child {
  font-size: 48rpx;
}

.login-item text:last-child {
  font-size: 24rpx;
  color: #666;
}

.footer-tip {
  margin-top: 80rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.link {
  color: #fff;
  margin: 0 4rpx;
}
