/* pages/post/post.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 表单 */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #ccc;
}

.form-textarea {
  width: 100%;
  height: 240rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.location-wrapper {
  width: 100%;
}

.form-input-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
}

.form-input.placeholder {
  color: #ccc;
}

.input-suffix {
  font-size: 28rpx;
  color: #07c160;
}

.error-tip {
  display: block;
  font-size: 24rpx;
  color: #ff4d4f;
  margin-top: 12rpx;
}

/* 提示卡片 */
.tips-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.tips-icon {
  width: 40rpx;
  height: 40rpx;
  background: #07c160;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-bottom: 40rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #ccc;
  opacity: 0.7;
}

/* 底部 */
.footer {
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.link {
  color: #07c160;
  margin: 0 4rpx;
}
