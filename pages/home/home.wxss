/* pages/home/home.wxss */
.container {
  padding-bottom: 160rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #fff;
}

.user-detail {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4rpx;
}

.user-phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 快捷入口 */
.quick-entry {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.2);
}

.entry-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.entry-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.post-icon {
  background: #07c16020;
  color: #07c160;
}

.order-icon {
  background: #576b9520;
  color: #576b95;
}

.merchant-icon {
  background: #fa9d3b20;
  color: #fa9d3b;
}

.chat-icon {
  background: #70a7e920;
  color: #70a7e9;
}

.entry-text {
  font-size: 24rpx;
  color: #fff;
}

/* 轮播图 */
.banner-section {
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-swiper {
  height: 240rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 服务分类 */
.category-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.category-list {
  white-space: nowrap;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 0 24rpx;
  margin-right: 24rpx;
}

.category-item:last-child {
  margin-right: 0;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

.merchant-guide {
  background: linear-gradient(135deg, #ffffff 0%, #eefaf4 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(7, 193, 96, 0.08);
}

.merchant-guide-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.merchant-guide-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2d3d;
  margin-bottom: 10rpx;
}

.merchant-guide-desc {
  display: block;
  font-size: 24rpx;
  color: #667085;
  line-height: 1.6;
}

.merchant-guide-badge {
  padding: 10rpx 20rpx;
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.merchant-guide-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.merchant-guide-btn::after {
  border: none;
}

/* 订单区域 */
.order-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-more {
  font-size: 26rpx;
  color: #07c160;
}

.order-list {
  margin-top: 24rpx;
}

.order-card {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.order-card:last-child {
  margin-bottom: 0;
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-dot.pending {
  background: #faad14;
}

.status-dot.accepted {
  background: #07c160;
}

.status-dot.processing {
  background: #1890ff;
}

.status-dot.completed {
  background: #52c41a;
}

.status-text {
  font-size: 24rpx;
  color: #666;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-info {
  flex: 1;
}

.order-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.order-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #ff4d4f;
}

.price-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.order-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.location-icon {
  font-size: 24rpx;
}

/* 空状态 */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  padding: 24rpx 60rpx;
  border: none;
}

.empty-btn::after {
  border: none;
}

/* 底部发布按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
}
