/* pages/profile/profile.wxss */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #fff;
}

.user-detail {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4rpx;
}

.user-phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 位置信息 */
.location-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.2);
}

.location-icon {
  font-size: 32rpx;
}

.location-text {
  flex: 1;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.refresh-btn {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 菜单区域 */
.menu-section {
  margin-bottom: 24rpx;
}

.menu-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 退出登录 */
.logout-btn {
  margin-top: 40rpx;
  text-align: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  color: #ff4d4f;
  font-size: 28rpx;
}

/* 未登录状态 */
.login-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.login-icon {
  font-size: 160rpx;
  margin-bottom: 32rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.login-btn {
  width: 400rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.login-btn::after {
  border: none;
}
