/* pages/merchant/merchant.wxss */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 商家信息卡片 */
.merchant-card {
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.merchant-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.merchant-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  background: #fff;
}

.merchant-info {
  flex: 1;
}

.merchant-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.merchant-rating {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.merchant-desc {
  margin-top: 20rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
}

.desc-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 8rpx;
}

.desc-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  line-height: 1.5;
}

.merchant-contact {
  display: flex;
  gap: 40rpx;
  margin-top: 24rpx;
}

.contact-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.contact-icon {
  font-size: 36rpx;
}

.contact-value {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 统计数据 */
.stats-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 功能入口 */
.function-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.function-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.function-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.function-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.function-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.nearby-icon {
  background: #07c16020;
  color: #07c160;
}

.orders-icon {
  background: #576b9520;
  color: #576b95;
}

.chat-icon {
  background: #70a7e920;
  color: #70a7e9;
}

.function-info {
  flex: 1;
}

.function-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.function-desc {
  font-size: 24rpx;
  color: #999;
}

.function-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 底部 */
.footer {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 0;
}

.footer-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.footer-icon {
  font-size: 40rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
