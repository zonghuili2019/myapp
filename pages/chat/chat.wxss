/* pages/chat/chat.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* 聊天头部 */
.chat-header {
  display: flex;
  align-items: center;
  height: 96rpx;
  padding: 0 24rpx;
  background: #fff;
  border-bottom: 2rpx solid #eee;
}

.header-left {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
}

.header-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 0 20rpx;
}

.header-info .avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.header-info .name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.header-right {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  font-size: 40rpx;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 24rpx;
}

.message-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
}

.empty-message {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 消息项 */
.message-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.message-item.sent {
  flex-direction: row-reverse;
}

.message-item .avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.message-content {
  flex: 1;
  max-width: 70%;
}

.message-sender {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.message-body {
  background: #fff;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
}

.message-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-word;
}

.message-text.recalled {
  color: #999;
}

.message-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

.message-time {
  font-size: 22rpx;
  color: #999;
}

.list-bottom {
  height: 40rpx;
}

/* 输入区域 */
.input-area {
  background: #fff;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

/* 工具栏 */
.toolbar {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.toolbar-item {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 16rpx;
}

.toolbar-icon {
  font-size: 32rpx;
}

/* 输入框 */
.input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
}

.message-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07c160;
  border-radius: 50%;
  border: none;
  margin-left: 16rpx;
}

.send-btn::after {
  border: none;
}

.send-icon {
  font-size: 28rpx;
  color: #fff;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
