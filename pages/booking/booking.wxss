page {
  background: #f5f7fb;
}

.container {
  padding: 32rpx;
  padding-bottom: 80rpx;
}

.header {
  padding: 20rpx 0 32rpx;
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #101828;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #667085;
  line-height: 1.6;
}

.merchant-card,
.form-card,
.tips-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(31, 45, 61, 0.05);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.merchant-top {
  display: flex;
  gap: 24rpx;
}

.merchant-logo {
  width: 108rpx;
  height: 108rpx;
  border-radius: 24rpx;
  background: #f2f4f7;
  flex-shrink: 0;
}

.merchant-main {
  flex: 1;
}

.merchant-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #101828;
  margin-bottom: 14rpx;
}

.merchant-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.merchant-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.merchant-tag.category {
  background: rgba(24, 144, 255, 0.12);
  color: #1890ff;
}

.merchant-tag.rating {
  background: rgba(255, 184, 0, 0.12);
  color: #d48806;
}

.merchant-tag.price {
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
}

.merchant-desc {
  display: block;
  font-size: 24rpx;
  color: #667085;
  line-height: 1.7;
}

.merchant-contact-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.contact-pill {
  flex: 1;
  height: 76rpx;
  border-radius: 18rpx;
  background: #f5f7fa;
  color: #344054;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item.half {
  flex: 1;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #344054;
  margin-bottom: 16rpx;
}

.form-input,
.picker-field,
.location-field {
  width: 100%;
  min-height: 96rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  padding: 0 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #101828;
}

.location-field {
  justify-content: space-between;
}

.location-text {
  flex: 1;
  line-height: 1.5;
}

.location-text.placeholder {
  color: #98a2b3;
}

.location-arrow {
  margin-left: 16rpx;
}

.form-textarea {
  width: 100%;
  height: 220rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #101828;
  line-height: 1.7;
}

.tips-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #101828;
  margin-bottom: 20rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.tips-item:last-child {
  margin-bottom: 0;
}

.tips-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #07c160;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
}

.tips-text {
  flex: 1;
  font-size: 24rpx;
  color: #667085;
  line-height: 1.7;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #d0d5dd;
}

.loading {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e4e7ec;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #98a2b3;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
