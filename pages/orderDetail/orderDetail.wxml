<!--pages/orderDetail/orderDetail.wxml-->
<view class="container" wx:if="{{order}}">
  <view class="order-header">
    <view class="order-status">
      <text class="status-dot {{order.status}}"></text>
      <text class="status-text">{{order.statusText}}</text>
    </view>
    <view class="order-price">
      <text class="price-symbol">¥</text>
      <text class="price-amount">{{order.price}}</text>
    </view>
  </view>

  <view class="info-card">
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <text class="info-value">{{order.orderId}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">发布时间</text>
      <text class="info-value">{{order.createdAt}}</text>
    </view>
  </view>

  <view class="detail-card">
    <text class="card-title">需求描述</text>
    <text class="card-content">{{order.description}}</text>
  </view>

  <view class="user-card" wx:if="{{order.clientId}}">
    <view class="user-info">
      <text class="user-label">客户</text>
      <text class="user-name">{{order.clientName}}</text>
    </view>
    <view class="user-phone" bindtap="makePhoneCall" data-phone="{{order.clientPhone}}">
      <text class="phone-icon">📞</text>
      <text class="phone-number">{{order.clientPhone}}</text>
    </view>
    <view class="user-location" bindtap="openLocation" data-lat="{{order.clientLocation.latitude}}" data-lng="{{order.clientLocation.longitude}}" data-address="{{order.clientLocation.address}}">
      <text class="location-icon">📍</text>
      <text class="location-text">{{order.clientLocation.address}}</text>
    </view>
    <view class="contact-btn" bindtap="contactOther" data-user-id="{{order.clientId}}" data-merchant-id="{{order.merchantId}}">
      <text>发送消息</text>
    </view>
  </view>

  <view class="user-card" wx:if="{{order.merchantId}}">
    <view class="user-info">
      <text class="user-label">商家</text>
      <text class="user-name">{{merchantInfo ? merchantInfo.name : '已接单'}}</text>
    </view>
    <view class="user-phone" bindtap="makePhoneCall" data-phone="{{merchantInfo.phone}}" wx:if="{{merchantInfo && merchantInfo.phone}}">
      <text class="phone-icon">📞</text>
      <text class="phone-number">{{merchantInfo.phone}}</text>
    </view>
    <view class="contact-btn" bindtap="contactOther" data-user-id="{{order.clientId}}" data-merchant-id="{{order.merchantId}}">
      <text>发送消息</text>
    </view>
  </view>

  <view class="action-bar" wx:if="{{userType === 'client'}}">
    <button class="action-btn cancel-btn" bindtap="cancelOrder" wx:if="{{order.status === 'pending'}}">
      <text>取消订单</text>
    </button>
    <button class="action-btn complete-btn" bindtap="completeOrder" wx:if="{{order.status === 'accepted'}}">
      <text>确认完成</text>
    </button>
  </view>

  <view class="action-bar" wx:if="{{userType === 'merchant' && order.status === 'pending'}}">
    <button class="action-btn accept-btn" bindtap="acceptOrder">
      <text>接单</text>
    </button>
  </view>
</view>

<view class="loading" wx:else>
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>
