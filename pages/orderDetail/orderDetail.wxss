/* pages/orderDetail/orderDetail.wxss */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 订单头部 */
.order-header {
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.order-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.status-dot.pending {
  background: #faad14;
}

.status-dot.accepted {
  background: #07c160;
}

.status-dot.processing {
  background: #1890ff;
}

.status-dot.completed {
  background: #52c41a;
}

.status-dot.cancelled {
  background: #999;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.order-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #ff4d4f;
}

.price-amount {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff4d4f;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

/* 详情卡片 */
.detail-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.card-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 用户卡片 */
.user-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.user-label {
  font-size: 24rpx;
  color: #999;
}

.user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.user-phone {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.phone-icon {
  font-size: 28rpx;
}

.phone-number {
  font-size: 28rpx;
  color: #333;
}

.user-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
  padding: 12rpx 0;
}

.location-icon {
  font-size: 24rpx;
}

.contact-btn {
  padding: 20rpx;
  background: #07c160;
  border-radius: 12rpx;
  text-align: center;
}

.contact-btn text {
  color: #fff;
  font-size: 28rpx;
}

/* 操作按钮 */
.action-bar {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 100rpx;
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.cancel-btn {
  background: #fff;
  color: #ff4d4f;
}

.complete-btn {
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  color: #fff;
}

.accept-btn {
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  color: #fff;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
